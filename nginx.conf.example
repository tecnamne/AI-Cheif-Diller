# Upstream РґР»СЏ AI Chatbot
upstream ai_chatbot {
    server ai-chatbot:3001;
    keepalive 32;
}

# platform service СѓР¶Рµ РґРѕСЃС‚СѓРїРµРЅ РІ СЃРµС‚Рё РєР°Рє "server:7777"
# РћС‚РґРµР»СЊРЅС‹Р№ upstream РЅРµ РЅСѓР¶РµРЅ - chatbot РѕР±СЂР°С‰Р°РµС‚СЃСЏ РЅР°РїСЂСЏРјСѓСЋ

server {
    listen 80;
    server_name chatbot-api.example.com;
    
    # Redirect HTTP to HTTPS
    return 301 https://$server_name$request_uri;
}

server {
    listen 443 ssl http2;
    server_name chatbot-api.example.com;

    # SSL Configuration
    ssl_certificate /etc/nginx/ssl/fullchain.pem;
    ssl_certificate_key /etc/nginx/ssl/privkey.pem;
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_ciphers ECDHE-ECDSA-AES128-GCM-SHA256:ECDHE-RSA-AES128-GCM-SHA256;
    ssl_prefer_server_ciphers off;
    ssl_session_cache shared:SSL:10m;
    ssl_session_timeout 1d;

    # Security Headers
    add_header X-Frame-Options "SAMEORIGIN" always;
    add_header X-Content-Type-Options "nosniff" always;
    add_header X-XSS-Protection "1; mode=block" always;
    add_header Referrer-Policy "strict-origin-when-cross-origin" always;

    # Gzip
    gzip on;
    gzip_types application/json text/plain application/javascript;
    gzip_min_length 1000;

    # =====================
    # AI Chatbot API Routes
    # =====================
    
    # Chat API
    location /ai-chat-api {
        proxy_pass http://ai_chatbot;
        proxy_http_version 1.1;
        
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        
        # Timeouts for long AI responses
        proxy_connect_timeout 60s;
        proxy_send_timeout 60s;
        proxy_read_timeout 120s;
        
        # Buffer settings
        proxy_buffering on;
        proxy_buffer_size 4k;
        proxy_buffers 8 32k;
    }

    # Scanner API
    location /scanner/api {
        proxy_pass http://ai_chatbot;
        proxy_http_version 1.1;
        
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        
        proxy_connect_timeout 60s;
        proxy_send_timeout 60s;
        proxy_read_timeout 300s;  # Scanner can take longer
    }

    # Health check endpoint
    location /health {
        proxy_pass http://ai_chatbot;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        
        # Quick timeout for health checks
        proxy_connect_timeout 5s;
        proxy_read_timeout 10s;
    }

    # Root endpoint (API info)
    location / {
        proxy_pass http://ai_chatbot;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
    }

    # =====================
    # Rate Limiting
    # =====================
    # Note: AI Chatbot already has built-in rate limiting
    # This is additional protection at Nginx level
    
    # limit_req_zone $binary_remote_addr zone=chat_limit:10m rate=10r/s;
    # location /api/chat {
    #     limit_req zone=chat_limit burst=20 nodelay;
    #     ...
    # }
}


  location /ai-chat-api {
    gzip on;
    gzip_comp_level 9;
    gzip_vary on;
    gzip_min_length  1000;

    proxy_pass http://demo-frontend.example.com:7001/ai-chat-api;

    # HTTP 1.1 support
    proxy_http_version 1.1;
    proxy_buffering off;
    proxy_set_header Host $http_host;
    proxy_set_header Upgrade $http_upgrade;
    proxy_set_header Connection $proxy_connection;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $proxy_x_forwarded_proto;
    proxy_set_header X-Forwarded-Ssl $proxy_x_forwarded_ssl;
    proxy_set_header X-Forwarded-Port $proxy_x_forwarded_port;

    # Longer timeouts for AI responses
    proxy_connect_timeout 60s;
    proxy_send_timeout 60s;
    proxy_read_timeout 120s;

    proxy_set_header Proxy "";
  }

