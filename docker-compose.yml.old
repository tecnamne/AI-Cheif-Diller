#       - PLATFORM_SERVICE_URL=http://platform-service:7777
#       - MONGODB_URI=mongodb://root:root@mongo:27017
#       - MONGODB_DATABASE=chatbot_demo
#       - ALLOWED_ORIGINS=https://chatbot-api.example.com
#     networks:
#       - your-network
#     depends_on:
#       - mongo
#       - server

