# ============================================
# Trading Platform Demo Chatbot - Environment Variables
# ============================================

# Server
NODE_ENV=development
PORT=3001

# Demo switch (set true for public/local demo)
DEMO_MODE=true
DEMO_USER_ID=demo-user

# Database
MONGODB_URI=mongodb://root:root@mongo:27017
MONGODB_DATABASE=chatbot_demo

# CORS
# Comma-separated list for local demo + frontend host
ALLOWED_ORIGINS=http://localhost:3001,http://localhost:4173,http://127.0.0.1:4173

# AI API keys (optional in DEMO_MODE)
# In demo mode Gemini is disabled and mocked responses are used.
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.0-flash
OPENAI_API_KEY=

# Gateway integration (optional in DEMO_MODE)
# Format: ws://<host>:<port>
BACKEND_MASTER_URI=ws://localhost:11700

# Optional internal references
BROKER_NAME=Demo Broker
ENVIRONMENT=demo

# Security / tokens
FRESHCHAT_JWT_SECRET=replace-me-if-you-use-auth

# Scanner defaults
SCANNER_ENABLED=true
SCANNER_ALERTS_ENABLED=true
SCANNER_ALERTS_TOP_WINNERS_ENABLED=true
SCANNER_ALERTS_TOP_BY_TRADE_COUNT_ENABLED=true
SCANNER_ALERTS_NEW_ACCOUNTS_ENABLED=true
SCANNER_ALERTS_INTERVAL_SECONDS=300
SCANNER_ALERTS_CONFIG_REFRESH_SECONDS=10
SCANNER_MORNING_HOUR=9
SCANNER_EVENING_HOUR=21
SCANNER_TOP_WINNERS=100
SCANNER_LOOKBACK_DAYS=7
SCANNER_EXCLUDE_NODES=

# Optional legacy adapter (previous naming kept for compatibility)
PLATFORM_SERVICE_URL=

# Limits
SESSION_TIMEOUT_MINUTES=30
MAX_HISTORY_MESSAGES=10
ALLOWED_PERSONAL_FIELDS=
MESSAGE_RETENTION_DAYS=0
SESSION_RETENTION_DAYS=0
BACKFILL_DATE_FIELDS=false
