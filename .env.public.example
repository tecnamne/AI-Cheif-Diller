# Public demo environment
# Copy values from this file when running the project as a public/local demo.

NODE_ENV=development
PORT=3001

# Demo mode disables external auth requirements and uses mock scanner alerts.
DEMO_MODE=true
DEMO_USER_ID=demo-user

# Local MongoDB. Docker Compose exposes Mongo on 27095.
MONGODB_URI=mongodb://root:root@localhost:27095/?authSource=admin
MONGODB_DATABASE=chatbot_demo

# Frontend/API origins for local development.
ALLOWED_ORIGINS=http://localhost:3001,http://localhost:4173,http://127.0.0.1:4173

# Optional AI providers. Leave empty for mocked/demo responses where supported.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
OPENAI_API_KEY=

# Optional gateway integration. Not required in DEMO_MODE.
BACKEND_MASTER_URI=
PLATFORM_SERVICE_URL=

# Public demo tenant labels.
BROKER_NAME=Demo Broker
ENVIRONMENT=demo

# Auth secret is only required when DEMO_MODE=false.
FRESHCHAT_JWT_SECRET=

# Mock scanner alerts.
SCANNER_ENABLED=true
SCANNER_ALERTS_ENABLED=true
SCANNER_ALERTS_TOP_WINNERS_ENABLED=true
SCANNER_ALERTS_TOP_BY_TRADE_COUNT_ENABLED=true
SCANNER_ALERTS_NEW_ACCOUNTS_ENABLED=true
SCANNER_ALERTS_INTERVAL_SECONDS=30
SCANNER_ALERTS_CONFIG_REFRESH_SECONDS=5
SCANNER_TOP_WINNERS=20
SCANNER_LOOKBACK_DAYS=7
SCANNER_EXCLUDE_NODES=

# Session/history limits.
SESSION_TIMEOUT_MINUTES=30
MAX_HISTORY_MESSAGES=10
ALLOWED_PERSONAL_FIELDS=
MESSAGE_RETENTION_DAYS=0
SESSION_RETENTION_DAYS=0
BACKFILL_DATE_FIELDS=false
